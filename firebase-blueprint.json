{
  "entities": {
    "users": {
      "title": "User",
      "description": "A user profile on the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "email": { "type": "string", "description": "The user's email address." },
        "bio": { "type": "string", "description": "A short biography." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user joined." }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "posts": {
      "title": "Post",
      "description": "A piece of writing or poetry.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The post's unique ID." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "title": { "type": "string", "description": "The title of the piece." },
        "content": { "type": "string", "description": "The body of the writing (Markdown)." },
        "category": { "type": "string", "enum": ["poetry", "prose", "essay", "letter"], "description": "The type of writing." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the post was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the post was last updated." },
        "isPublic": { "type": "boolean", "description": "Whether the post is visible to others." },
        "imageUrl": { "type": "string", "description": "An optional image URL for the post." },
        "likesCount": { "type": "integer", "description": "The number of likes on the post." }
      },
      "required": ["authorId", "title", "content", "category", "createdAt", "isPublic"]
    },
    "likes": {
      "title": "Like",
      "description": "A user's like on a post.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the user who liked the post." },
        "postId": { "type": "string", "description": "The ID of the post liked." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the like was created." }
      },
      "required": ["uid", "postId", "createdAt"]
    },
    "comments": {
      "title": "Comment",
      "description": "A user comment on a post.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The comment's unique ID." },
        "postId": { "type": "string", "description": "The ID of the post being commented on." },
        "authorId": { "type": "string", "description": "The UID of the commenter." },
        "authorName": { "type": "string", "description": "The name of the commenter." },
        "authorPhoto": { "type": "string", "description": "The photo URL of the commenter." },
        "content": { "type": "string", "description": "The body of the comment." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the comment was created." }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt"]
    },
    "reports": {
      "title": "Report",
      "description": "A user report on a post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string", "description": "The ID of the post being reported." },
        "postTitle": { "type": "string", "description": "The title of the post being reported." },
        "authorId": { "type": "string", "description": "The UID of the author of the post." },
        "reporterId": { "type": "string", "description": "The UID of the reporter." },
        "reporterEmail": { "type": "string", "description": "The email of the reporter." },
        "reason": { "type": "string", "description": "The reason for reporting." },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"], "description": "The status of the report." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created." }
      },
      "required": ["postId", "reporterId", "reason", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents."
    },
    "/posts/{postId}": {
      "schema": "posts",
      "description": "Writing and poetry posts."
    },
    "/likes/{likeId}": {
      "schema": "likes",
      "description": "User likes on posts."
    },
    "/comments/{commentId}": {
      "schema": "comments",
      "description": "User comments on posts."
    },
    "/reports/{reportId}": {
      "schema": "reports",
      "description": "User reports on posts."
    }
  }
}
